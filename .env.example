TELEGRAM_TOKEN_ENCRYPTION_KEY=change-me-local-telegram-encryption-secret
TELEGRAM_FSM_STATE_TTL_SECONDS=86400
TELEGRAM_FSM_DATA_TTL_SECONDS=86400
TELEGRAM_UPDATE_IDEMPOTENCY_TTL_SECONDS=86400
TEST_CLINIC_SLUG=test-clinic
